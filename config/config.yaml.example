_setup_complete: false   # set to true by the setup wizard

rmf:
  api_url: http://localhost:8000
  jwt_token: ""          # leave blank to skip auth (dev mode)

llm:
  backend: claude        # claude | openai | ollama
  model: claude-sonnet-4-6
  api_key: ""            # reads ANTHROPIC_API_KEY / OPENAI_API_KEY from env if blank
  ollama_url: http://localhost:11434

fleet_scanner:
  rmf_poll_interval: 10  # seconds between RMF API polls
  wifi_mdns: true        # enable mDNS/Zeroconf WiFi discovery
  bluetooth: true        # enable BLE discovery
  ble_service_uuid: "12345678-1234-1234-1234-123456789abc"
  ble_scan_duration: 5   # seconds per BLE scan cycle

dashboard:
  port: 18789
  host: 0.0.0.0

hitl:
  auto_approve_timeout: 60  # seconds to wait before auto-escalating; 0 = always wait
  require_approval_for:
    - cancel_task
    - dispatch_task  # set to [] to never require approval

gazebo:
  # rosbridge_suite WebSocket running in WSL2
  # Run in WSL2: ros2 launch rosbridge_server rosbridge_websocket_launch.xml
  rosbridge_url: ws://172.28.144.1:9090   # replace with your WSL2 IP
  default_level: L1                        # default map floor to display
